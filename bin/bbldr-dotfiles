#!/usr/bin/env bash
set -Eeuo pipefail

script_path="${BASH_SOURCE[0]}"
while [ -L "$script_path" ]; do
  script_dir="$(cd "$(dirname "$script_path")" && pwd)"
  script_path="$(readlink "$script_path")"
  case "$script_path" in /*) ;; *) script_path="$script_dir/$script_path" ;; esac
done
repo_root="$(cd "$(dirname "$script_path")/.." && pwd)"
packages_file="$repo_root/config/packages.tsv"
targets_file="$repo_root/config/targets.tsv"
backup_root="${BBLDR_DOTFILES_BACKUP_DIR:-$HOME/.config/bbldr/backups/dotfiles}"
assume_yes="${BBLDR_ASSUME_YES:-0}"
version="$(tr -d '[:space:]' < "$repo_root/VERSION")"

usage() {
  cat <<'EOF'
Usage: bbldr dotfiles <command> [options]

Commands:
  install [PACKAGE...]       Install dependencies and configurations
  update                     Fast-forward the repository and diagnose it
  status                     Show repository and managed-path status
  doctor                     Diagnose dependencies, links, and repository state
  packages                   List packages, dependencies, and installation state
  backups                    List installation records
  restore [PACKAGE...]       Restore configuration from a backup
  uninstall [PACKAGE...]     Restore pre-install configuration safely
  purge                      Restore configuration and remove the project CLI
  scaffold app NAME          Create a contributor package scaffold
  check                      Run the contributor validation suite
  version                    Print module version
  help                       Show this help

Run "bbldr dotfiles <command> --help" for command-specific options.
EOF
}

log() { printf '%s\n' "$*"; }

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

confirm() {
  local prompt="$1" reply
  if [ "$assume_yes" = 1 ]; then return 0; fi
  [ -t 0 ] || die "Confirmation required; rerun with --yes."
  printf '%s [y/N] ' "$prompt"
  read -r reply
  case "$reply" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

platform() {
  case "$(uname -s)" in
    Darwin) printf 'macos\n' ;;
    Linux)
      if command -v apt-get >/dev/null 2>&1; then printf 'debian\n'; else printf 'linux\n'; fi
      ;;
    *) printf 'unsupported\n' ;;
  esac
}

require_command() {
  command -v "$1" >/dev/null 2>&1 || die "Missing required command: $1"
}

package_exists() {
  local wanted="$1" package _default _dependency _docs _title _description
  while IFS=$'\t' read -r package _default _dependency _docs _title _description; do
    [ "$package" = package ] && continue
    [ "$package" = "$wanted" ] && return 0
  done < "$packages_file"
  return 1
}

default_packages() {
  local package default _dependency _docs _title _description
  while IFS=$'\t' read -r package default _dependency _docs _title _description; do
    [ "$package" = package ] && continue
    [ "$default" = 1 ] && printf '%s\n' "$package"
  done < "$packages_file"
}

all_packages() {
  local package _default _dependency _docs _title _description
  while IFS=$'\t' read -r package _default _dependency _docs _title _description; do
    [ "$package" = package ] && continue
    printf '%s\n' "$package"
  done < "$packages_file"
}

validate_packages() {
  local package
  for package in "$@"; do
    package_exists "$package" || die "Unknown package: $package"
  done
}

selection_needs() {
  local wanted="$1" selected package _default dependency _docs _title _description
  shift
  for selected in "$@"; do
    while IFS=$'\t' read -r package _default dependency _docs _title _description; do
      [ "$package" = "$selected" ] || continue
      case ",$dependency," in *",$wanted,"*) return 0 ;; esac
    done < "$packages_file"
  done
  return 1
}

selection_contains() {
  local wanted="$1" selected
  shift
  for selected in "$@"; do [ "$selected" = "$wanted" ] && return 0; done
  return 1
}

targets_for_package() {
  local wanted="$1" package target source
  while IFS=$'\t' read -r package target source; do
    [ "$package" = package ] && continue
    [ "$package" = "$wanted" ] || continue
    printf '%s\t%s\n' "$HOME/$target" "$repo_root/$source"
  done < "$targets_file"
}

items_for_package() {
  local wanted="$1" target source source_file relative
  while IFS=$'\t' read -r target source; do
    if [ -d "$source" ]; then
      while IFS= read -r source_file; do
        relative="${source_file#"$source"/}"
        printf '%s\t%s\n' "$target/$relative" "$source_file"
      done < <(find "$source" \( -type f -o -type l \) -print | sort)
    else
      printf '%s\t%s\n' "$target" "$source"
    fi
  done < <(targets_for_package "$wanted")
}

resolve_link() {
  local path="$1" link
  link="$(readlink "$path")"
  case "$link" in /*) realpath "$link" ;; *) realpath "$(dirname "$path")/$link" ;; esac
}

link_matches() {
  [ -L "$1" ] && [ "$(resolve_link "$1")" = "$(realpath "$2")" ]
}

target_is_managed() {
  local target="$1" source="$2" source_file relative live
  if [ -f "$source" ] || [ -L "$source" ]; then
    link_matches "$target" "$source"
    return
  fi
  [ -d "$target" ] || return 1
  while IFS= read -r source_file; do
    relative="${source_file#"$source"/}"
    live="$target/$relative"
    link_matches "$live" "$source_file" || return 1
  done < <(find "$source" \( -type f -o -type l \) -print)
}

target_state() {
  local target="$1" source="$2" item_target item_source state new=0 managed=0 conflicts=0
  if [ -d "$source" ]; then
    while IFS=$'\t' read -r item_target item_source; do
      state="$(target_state "$item_target" "$item_source")"
      case "$state" in new) new=$((new + 1)) ;; managed) managed=$((managed + 1)) ;; *) conflicts=$((conflicts + 1)) ;; esac
    done < <(items_for_source "$target" "$source")
    if [ "$conflicts" -gt 0 ]; then printf 'backup required\n'
    elif [ "$new" -gt 0 ] && [ "$managed" -gt 0 ]; then printf 'partial\n'
    elif [ "$managed" -gt 0 ]; then printf 'managed\n'
    else printf 'new\n'
    fi
  elif [ ! -e "$target" ] && [ ! -L "$target" ]; then printf 'new\n'
  elif target_is_managed "$target" "$source"; then printf 'managed\n'
  else printf 'backup required\n'
  fi
}

items_for_source() {
  local target="$1" source="$2" source_file relative
  while IFS= read -r source_file; do
    relative="${source_file#"$source"/}"
    printf '%s\t%s\n' "$target/$relative" "$source_file"
  done < <(find "$source" \( -type f -o -type l \) -print | sort)
}

package_is_installed() {
  local target source
  while IFS=$'\t' read -r target source; do
    link_matches "$target" "$source" && return 0
  done < <(items_for_package "$1")
  return 1
}

installed_packages() {
  local package
  while IFS= read -r package; do package_is_installed "$package" && printf '%s\n' "$package"; done < <(all_packages)
}

canonical_future_path() {
  local path="$1" suffix="" name
  while [ ! -e "$path" ] && [ ! -L "$path" ] && [ "$path" != / ]; do
    name="${path##*/}"
    suffix="/$name$suffix"
    path="$(dirname "$path")"
  done
  printf '%s%s\n' "$(realpath "$path")" "$suffix"
}

canonical_target_path() {
  printf '%s/%s\n' "$(canonical_future_path "$(dirname "$1")")" "${1##*/}"
}

validate_runtime_paths() {
  local package target _source canonical_backup canonical_home canonical_repo canonical_target
  case "$backup_root" in /*) ;; *) die "Backup directory must be absolute: $backup_root" ;; esac
  [[ "$backup_root" != / && "$backup_root" != "$HOME" ]] || die "Unsafe backup directory: $backup_root"
  canonical_backup="$(canonical_future_path "$backup_root")"
  canonical_home="$(canonical_future_path "$HOME")"
  canonical_repo="$(canonical_future_path "$repo_root")"
  case "$canonical_backup/" in "$canonical_repo/"*) die "Backup directory overlaps the repository: $backup_root" ;; esac
  case "$canonical_repo/" in "$canonical_backup/"*) die "Backup directory contains the repository: $backup_root" ;; esac
  while IFS= read -r package; do
    while IFS=$'\t' read -r target _source; do
      if [ -d "$_source" ]; then canonical_target="$(canonical_future_path "$target")"
      else canonical_target="$(canonical_target_path "$target")"
      fi
      case "$canonical_target/" in "$canonical_home/"*) ;; *) die "Managed target resolves outside HOME: $target" ;; esac
      case "$canonical_backup/" in "$canonical_target/"*) die "Backup directory overlaps a managed target: $target" ;; esac
      case "$canonical_target/" in "$canonical_backup/"*) die "Backup directory contains a managed target: $target" ;; esac
    done < <(targets_for_package "$package")
  done < <(all_packages)
}

activate_homebrew() {
  local candidate
  command -v brew >/dev/null 2>&1 && return
  for candidate in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [ -x "$candidate" ]; then eval "$("$candidate" shellenv)"; return; fi
  done
}

install_homebrew() {
  activate_homebrew
  command -v brew >/dev/null 2>&1 && return
  [ "$(platform)" = macos ] || die "Homebrew automatic installation is only supported on macOS."
  log "Installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  activate_homebrew
  require_command brew
}

brew_install_formula() {
  if brew list --formula "$1" >/dev/null 2>&1; then log "Already installed: $1"; else brew install "$1"; fi
}

brew_install_cask() {
  if brew list --cask "$1" >/dev/null 2>&1; then log "Already installed: $1"; else brew install --cask "$1"; fi
}

apt_install() {
  local missing=() item
  for item in "$@"; do dpkg -s "$item" >/dev/null 2>&1 || missing+=("$item"); done
  if [ "${#missing[@]}" -gt 0 ]; then
    log "Installing APT packages: ${missing[*]}"
    sudo apt-get update
    sudo apt-get install -y "${missing[@]}"
  fi
}

version_at_least() {
  [ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | head -n 1)" = "$2" ]
}

check_neovim_version() {
  local current
  command -v nvim >/dev/null 2>&1 || return 1
  current="$(nvim --version | head -n 1 | sed -E 's/.*v([0-9]+\.[0-9]+\.[0-9]+).*/\1/')"
  version_at_least "$current" "0.10.0"
}

install_current_neovim_linux() {
  local arch asset tmp_dir install_dir command_path
  case "$(uname -m)" in
    x86_64) arch=x86_64 ;;
    aarch64|arm64) arch=arm64 ;;
    *) die "Unsupported Neovim architecture: $(uname -m)" ;;
  esac
  asset="nvim-linux-${arch}.tar.gz"
  tmp_dir="$(mktemp -d)"
  install_dir="$HOME/.local/opt/bbldr-neovim"
  command_path="$HOME/.local/bin/nvim"
  if [ -e "$command_path" ] && [ ! -L "$command_path" ]; then die "Refusing to overwrite existing command: $command_path"; fi
  if [ -L "$command_path" ] && [[ "$(readlink "$command_path")" != "$install_dir"/* ]]; then
    die "Refusing to replace unrelated symlink: $command_path"
  fi
  log "Installing current Neovim release in $install_dir"
  curl -fsSL "https://github.com/neovim/neovim/releases/latest/download/$asset" -o "$tmp_dir/nvim.tar.gz"
  tar -xzf "$tmp_dir/nvim.tar.gz" -C "$tmp_dir"
  mkdir -p "$HOME/.local/opt" "$HOME/.local/bin"
  if [ -d "$install_dir" ]; then mv "$install_dir" "$install_dir.previous-$(date +%Y%m%d-%H%M%S)"; fi
  mv "$tmp_dir/nvim-linux-${arch}" "$install_dir"
  ln -sfn "$install_dir/bin/nvim" "$command_path"
  rm -rf "$tmp_dir"
  export PATH="$HOME/.local/bin:$PATH"
}

install_cli_dependencies() {
  local -a packages=("$@") apt_packages=(stow ca-certificates)
  case "$(platform)" in
    macos)
      install_homebrew
      brew_install_formula stow
      if selection_contains nvim "${packages[@]}"; then brew_install_formula neovim; brew_install_formula ripgrep; fi
      if selection_contains tmux "${packages[@]}"; then brew_install_formula tmux; fi
      ;;
    debian)
      selection_contains nvim "${packages[@]}" && apt_packages+=(ripgrep)
      selection_contains tmux "${packages[@]}" && apt_packages+=(tmux)
      selection_contains zsh "${packages[@]}" && apt_packages+=(zsh)
      apt_install "${apt_packages[@]}"
      if selection_contains nvim "${packages[@]}"; then check_neovim_version || install_current_neovim_linux; fi
      ;;
    *) die "Automatic CLI installation supports macOS and Ubuntu/Debian only." ;;
  esac
}

install_wezterm_dependency() {
  case "$(platform)" in
    macos) install_homebrew; brew_install_cask wezterm ;;
    debian)
      if command -v wezterm >/dev/null 2>&1; then log "Already installed: wezterm"; return; fi
      apt_install ca-certificates curl gnupg
      curl -fsSL https://apt.fury.io/wez/gpg.key | sudo gpg --yes --dearmor -o /usr/share/keyrings/wezterm-fury.gpg
      printf '%s\n' 'deb [signed-by=/usr/share/keyrings/wezterm-fury.gpg] https://apt.fury.io/wez/ * *' | sudo tee /etc/apt/sources.list.d/wezterm.list >/dev/null
      sudo chmod 644 /usr/share/keyrings/wezterm-fury.gpg
      sudo apt-get update
      sudo apt-get install -y wezterm
      ;;
    *) log "Install WezTerm manually on this Linux distribution." ;;
  esac
}

install_nerd_font_dependency() {
  local font_dir tmp_dir
  case "$(platform)" in
    macos) install_homebrew; brew_install_cask font-jetbrains-mono-nerd-font ;;
    debian)
      apt_install curl xz-utils fontconfig
      font_dir="$HOME/.local/share/fonts/JetBrainsMonoNerdFont"
      if find "$font_dir" -type f -name '*.ttf' -print -quit 2>/dev/null | grep -q .; then
        log "Already installed: JetBrainsMono Nerd Font"
        return
      fi
      tmp_dir="$(mktemp -d)"
      curl -fsSL https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz -o "$tmp_dir/font.tar.xz"
      mkdir -p "$font_dir"
      tar -xJf "$tmp_dir/font.tar.xz" -C "$font_dir"
      rm -rf "$tmp_dir"
      command -v fc-cache >/dev/null 2>&1 && fc-cache -f "$font_dir"
      ;;
    *) log "Install JetBrainsMono Nerd Font manually on this platform." ;;
  esac
}

install_oh_my_zsh_dependency() {
  if [ -d "$HOME/.oh-my-zsh" ]; then log "Already installed: Oh My Zsh"; return; fi
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
}

install_zsh_autosuggestions_dependency() {
  local plugin_dir="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/zsh-autosuggestions"
  if [ -d "$plugin_dir" ]; then log "Already installed: zsh-autosuggestions"; return; fi
  [ -d "$HOME/.oh-my-zsh" ] || { log "Skipping zsh-autosuggestions because Oh My Zsh is not installed."; return; }
  git clone https://github.com/zsh-users/zsh-autosuggestions "$plugin_dir"
}

install_stow() {
  command -v stow >/dev/null 2>&1 && return
  case "$(platform)" in
    macos) install_homebrew; brew_install_formula stow ;;
    debian) apt_install stow ;;
    *) die "GNU Stow is missing; install it manually and rerun." ;;
  esac
}

bbldr_is_managed() {
  local path="$HOME/.local/bin/bbldr"
  [ ! -e "$path" ] || grep -q '^# bbldr-dispatcher: become-builder$' "$path" 2>/dev/null
}

module_command_is_safe() {
  local path="$HOME/.local/bin/bbldr-dotfiles"
  [ ! -e "$path" ] && [ ! -L "$path" ] && return
  [ -L "$path" ] && [ "$(resolve_link "$path")" = "$(realpath "$repo_root/bin/bbldr-dotfiles")" ]
}

check_cli_collisions() {
  local existing
  bbldr_is_managed || die "Refusing to overwrite an unrelated command: $HOME/.local/bin/bbldr"
  module_command_is_safe || die "Refusing to overwrite an unrelated command: $HOME/.local/bin/bbldr-dotfiles"
  existing="$(command -v bbldr 2>/dev/null || true)"
  if [ -n "$existing" ] && ! grep -q '^# bbldr-dispatcher: become-builder$' "$existing" 2>/dev/null; then
    die "Refusing to shadow an unrelated bbldr command in PATH: $existing"
  fi
  existing="$(command -v bbldr-dotfiles 2>/dev/null || true)"
  if [ -n "$existing" ] && [ "$(realpath "$existing")" != "$(realpath "$repo_root/bin/bbldr-dotfiles")" ]; then
    die "Refusing to shadow an unrelated bbldr-dotfiles command in PATH: $existing"
  fi
}

install_cli_commands() {
  mkdir -p "$HOME/.local/bin"
  check_cli_collisions
  cp "$repo_root/bin/bbldr" "$HOME/.local/bin/bbldr"
  chmod +x "$HOME/.local/bin/bbldr"
  ln -sfn "$repo_root/bin/bbldr-dotfiles" "$HOME/.local/bin/bbldr-dotfiles"
}

show_install_plan() {
  local install_cli_tools="$1" install_wezterm="$2" install_font="$3" install_omz="$4" install_suggestions="$5" install_configs="$6"
  shift 6
  local package target source state
  printf '\nInstallation plan\n'
  printf '  Platform: %s (%s)\n' "$(platform)" "$(uname -m)"
  printf '  Repository: %s\n' "$repo_root"
  printf '  Packages:'
  printf ' %s' "$@"
  printf '\n  Dependencies:\n'
  printf '    CLI tools: %s\n' "$([ "$install_cli_tools" = 1 ] && printf yes || printf no)"
  printf '    WezTerm: %s\n' "$([ "$install_wezterm" = 1 ] && printf yes || printf no)"
  printf '    Nerd Font: %s\n' "$([ "$install_font" = 1 ] && printf yes || printf no)"
  printf '    Oh My Zsh: %s\n' "$([ "$install_omz" = 1 ] && printf yes || printf no)"
  printf '    zsh-autosuggestions: %s\n' "$([ "$install_suggestions" = 1 ] && printf yes || printf no)"
  printf '  Configuration links: %s\n' "$([ "$install_configs" = 1 ] && printf yes || printf no)"
  if [ "$install_configs" = 1 ]; then
    printf '  Managed targets:\n'
    for package in "$@"; do
      while IFS=$'\t' read -r target source; do
        state="$(target_state "$target" "$source")"
        printf '    %-16s %-16s %s\n' "$package" "$state" "$target"
      done < <(targets_for_package "$package")
    done
    printf '  Backup directory: %s\n' "$backup_root"
  fi
  printf '  Global command: %s\n\n' "$HOME/.local/bin/bbldr"
}

run_id=""
run_dir=""
manifest=""
changed_targets=0

create_manifest() {
  local suffix=0 base
  base="$(date +%Y%m%d-%H%M%S)"
  run_id="$base"
  while [ -e "$backup_root/$run_id" ]; do suffix=$((suffix + 1)); run_id="$base-$suffix"; done
  run_dir="$backup_root/$run_id"
  manifest="$run_dir/manifest.tsv"
  mkdir -p "$run_dir"
  printf '2\n' > "$run_dir/manifest-version"
  printf 'state\tpackage\ttarget\tsource\tbackup\n' > "$manifest"
  printf 'running\n' > "$run_dir/status"
}

backup_path() { printf '%s%s\n' "$run_dir" "$1"; }

backup_existing_targets() {
  local package target source backup state
  for package in "$@"; do
    while IFS=$'\t' read -r target source; do
      backup="$(backup_path "$target")"
      if [ ! -e "$target" ] && [ ! -L "$target" ]; then
        state=absent
        changed_targets=1
      elif target_is_managed "$target" "$source"; then
        state=managed
      else
        state=moved
        changed_targets=1
        mkdir -p "$(dirname "$backup")"
        log "Backing up $target to $backup"
        printf '%s\t%s\t%s\t%s\t%s\n' "$state" "$package" "$target" "$source" "$backup" >> "$manifest"
        mv "$target" "$backup"
        continue
      fi
      printf '%s\t%s\t%s\t%s\t%s\n' "$state" "$package" "$target" "$source" "$backup" >> "$manifest"
    done < <(items_for_package "$package")
  done
}

remove_source_links() {
  local target="$1" source="$2" source_file relative live
  if [ -f "$source" ] || [ -L "$source" ]; then
    if link_matches "$target" "$source"; then rm "$target"; fi
    return 0
  fi
  while IFS= read -r source_file; do
    relative="${source_file#"$source"/}"
    live="$target/$relative"
    if link_matches "$live" "$source_file"; then rm "$live"; fi
  done < <(find "$source" \( -type f -o -type l \) -print)
  find "$target" -depth -type d -empty -delete 2>/dev/null || true
}

rollback_install() {
  local state _package target source backup
  log "Installation failed; restoring files from $run_id"
  tail -n +2 "$manifest" | while IFS=$'\t' read -r state _package target source backup; do
    case "$state" in
      absent) remove_source_links "$target" "$source" ;;
      moved)
        remove_source_links "$target" "$source"
        if [ ! -e "$target" ] && [ ! -L "$target" ] && { [ -e "$backup" ] || [ -L "$backup" ]; }; then
          mkdir -p "$(dirname "$target")"
          mv "$backup" "$target"
        fi
        ;;
    esac
  done
  printf 'rolled-back\n' > "$run_dir/status"
}

install_failure() {
  local exit_code="${1:-1}"
  trap - ERR INT TERM
  if [ -n "$manifest" ] && [ -f "$manifest" ] && [ "$(cat "$run_dir/status" 2>/dev/null || true)" = running ]; then
    rollback_install || true
  fi
  exit "$exit_code"
}

link_packages() {
  local simulation_output
  simulation_output="$(mktemp)"
  if ! stow --simulate --no-folding --target="$HOME" --dir="$repo_root" "$@" >"$simulation_output" 2>&1; then
    cat "$simulation_output" >&2
    rm -f "$simulation_output"
    return 1
  fi
  rm -f "$simulation_output"
  stow --no-folding --target="$HOME" --dir="$repo_root" "$@"
}

command_install() {
  local dry_run=0 config_only=0 install_cli_tools=0 install_wezterm=0 install_font=0 install_omz=0 install_suggestions=0 install_configs=1
  local restore_id
  local -a packages=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --dry-run) dry_run=1; shift ;;
      --yes|-y) assume_yes=1; shift ;;
      --config-only) config_only=1; shift ;;
      --help|-h)
        cat <<'EOF'
Usage: bbldr dotfiles install [--dry-run] [--yes] [--config-only] [PACKAGE...]

Install selected dependencies and configuration packages. With no package
arguments, every default package is selected.
EOF
        return
        ;;
      --*) die "Unknown install option: $1" ;;
      *) packages+=("$1"); shift ;;
    esac
  done
  validate_registry
  if [ "${#packages[@]}" -eq 0 ]; then
    while IFS= read -r package; do packages+=("$package"); done < <(default_packages)
  fi
  validate_packages "${packages[@]}"
  validate_runtime_paths
  require_command git
  require_command curl
  check_cli_collisions

  if [ "$config_only" != 1 ]; then
    if [ "$assume_yes" = 1 ]; then
      selection_needs cli "${packages[@]}" && install_cli_tools=1
      selection_needs wezterm "${packages[@]}" && install_wezterm=1
      install_font=1
      if selection_needs shell "${packages[@]}"; then install_omz=1; install_suggestions=1; fi
    else
      if selection_needs cli "${packages[@]}"; then
        confirm "Install the CLI tools required by the selected packages?" && install_cli_tools=1
      fi
      if selection_needs wezterm "${packages[@]}"; then confirm "Install WezTerm?" && install_wezterm=1; fi
      confirm "Install JetBrainsMono Nerd Font?" && install_font=1
      if selection_needs shell "${packages[@]}"; then
        confirm "Install Oh My Zsh?" && install_omz=1
        confirm "Install zsh-autosuggestions?" && install_suggestions=1
      fi
    fi
  fi
  if [ "$assume_yes" != 1 ] && ! confirm "Install selected dotfiles configurations?"; then install_configs=0; fi

  show_install_plan "$install_cli_tools" "$install_wezterm" "$install_font" "$install_omz" "$install_suggestions" "$install_configs" "${packages[@]}"
  if [ "$dry_run" = 1 ]; then log "Dry run complete; no changes were made."; return; fi
  confirm "Apply this installation plan?" || { log "Installation cancelled."; return; }

  [ "$install_cli_tools" != 1 ] || install_cli_dependencies "${packages[@]}"
  [ "$install_wezterm" != 1 ] || install_wezterm_dependency
  [ "$install_font" != 1 ] || install_nerd_font_dependency
  [ "$install_omz" != 1 ] || install_oh_my_zsh_dependency
  [ "$install_suggestions" != 1 ] || install_zsh_autosuggestions_dependency

  install_cli_commands
  if [ "$install_configs" != 1 ]; then log "Installed bbldr without dotfiles configuration links."; return; fi
  install_stow
  create_manifest
  trap 'install_failure $?' ERR
  trap 'install_failure 130' INT TERM
  backup_existing_targets "${packages[@]}"
  log "Installing packages: ${packages[*]}"
  link_packages "${packages[@]}"
  printf 'complete\n' > "$run_dir/status"
  trap - ERR INT TERM
  if [ "$changed_targets" = 1 ] || [ ! -f "$backup_root/latest" ]; then printf '%s\n' "$run_id" > "$backup_root/latest"; fi
  restore_id="$(cat "$backup_root/latest")"
  log "Installation record: $run_dir"
  log "Restore command: bbldr dotfiles restore --backup $restore_id"
  if [[ ":$PATH:" != *":$HOME/.local/bin:"* ]]; then
    log "Open a new Zsh session or add $HOME/.local/bin to PATH before running bbldr."
  fi
  log "Installation complete."
}

directory_is_safe() {
  local target="$1" source="$2" live relative expected
  [ -d "$target" ] || return 0
  while IFS= read -r live; do
    relative="${live#"$target"/}"
    expected="$source/$relative"
    if [ ! -e "$expected" ] && [ ! -L "$expected" ]; then return 1; fi
    link_matches "$live" "$expected" || return 1
  done < <(find "$target" \( -type f -o -type l \) -print)
}

restore_target_is_safe() {
  local target="$1" source="$2"
  if [ ! -e "$target" ] && [ ! -L "$target" ]; then return 0; fi
  if [ -d "$source" ]; then
    [ -d "$target" ] && [ ! -L "$target" ] || return 1
    directory_is_safe "$target" "$source"
  else
    link_matches "$target" "$source"
  fi
}

restore_remove_links() { remove_source_links "$1" "$2"; }

valid_backup_id() {
  [[ "$1" =~ ^[0-9]{8}-[0-9]{6}(-[0-9]+)?$ ]]
}

validate_manifest_row() {
  local package="$1" target="$2" source="$3" backup="$4" record_dir="$5"
  package_exists "$package" || die "Manifest contains an unknown package: $package"
  case "/$target/$source/$backup/" in */../*) die "Manifest contains parent-directory traversal" ;; esac
  case "$target" in "$HOME"/*) ;; *) die "Manifest target is outside HOME: $target" ;; esac
  case "$source" in "$repo_root"/*) ;; *) die "Manifest source is outside the repository: $source" ;; esac
  case "$backup" in "$record_dir"/*) ;; *) die "Manifest backup is outside its record: $backup" ;; esac
  manifest_row_is_registered "$package" "$target" "$source" || die "Manifest row is not registered for $package: $target"
}

manifest_row_is_registered() {
  local wanted="$1" row_target="$2" row_source="$3" target source relative
  while IFS=$'\t' read -r target source; do
    if [ "$row_target" = "$target" ] && [ "$row_source" = "$source" ]; then return 0; fi
    [ -d "$source" ] || continue
    case "$row_source" in
      "$source"/*)
        relative="${row_source#"$source"/}"
        [ "$row_target" = "$target/$relative" ] && return 0
        ;;
    esac
  done < <(targets_for_package "$wanted")
  return 1
}

command_restore() {
  local backup_id=latest restore_yes=0 run_dir manifest row state package target source backup reply staging
  local -a selected_packages=() rows=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --backup) [ "$#" -ge 2 ] || die "--backup requires a value"; backup_id="$2"; shift 2 ;;
      --yes|-y) restore_yes=1; shift ;;
      --help|-h)
        cat <<'EOF'
Usage: bbldr dotfiles restore [--backup latest|ID] [--yes] [PACKAGE...]

Restore files recorded before a dotfiles installation.
EOF
        return
        ;;
      --*) die "Unknown restore option: $1" ;;
      *) selected_packages+=("$1"); shift ;;
    esac
  done
  validate_registry
  [ "${#selected_packages[@]}" -eq 0 ] || validate_packages "${selected_packages[@]}"
  validate_runtime_paths
  if [ "$backup_id" = latest ]; then
    [ -f "$backup_root/latest" ] || die "No completed installation record found in $backup_root"
    backup_id="$(cat "$backup_root/latest")"
  fi
  valid_backup_id "$backup_id" || die "Invalid backup id: $backup_id"
  run_dir="$backup_root/$backup_id"
  manifest="$run_dir/manifest.tsv"
  [ -f "$manifest" ] || die "Manifest not found: $manifest"
  [ "$(cat "$run_dir/status" 2>/dev/null || true)" = complete ] || die "Backup record is not complete: $backup_id"

  while IFS=$'\t' read -r state package target source backup; do
    [ "$state" = state ] && continue
    case "$state" in absent|moved|managed) ;; *) die "Unknown manifest state: $state" ;; esac
    validate_manifest_row "$package" "$target" "$source" "$backup" "$run_dir"
    if [ "${#selected_packages[@]}" -gt 0 ]; then
      local selected=0 wanted
      for wanted in "${selected_packages[@]}"; do [ "$wanted" = "$package" ] && selected=1; done
      [ "$selected" = 1 ] || continue
    fi
    rows+=("$state"$'\t'"$package"$'\t'"$target"$'\t'"$source"$'\t'"$backup")
  done < "$manifest"
  [ "${#rows[@]}" -gt 0 ] || die "No matching packages in $manifest"

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r state package target source backup <<< "$row"
    restore_target_is_safe "$target" "$source" || die "Refusing to overwrite a modified path: $target"
    if [ "$state" = moved ] && [ ! -e "$backup" ] && [ ! -L "$backup" ]; then die "Backup item is missing: $backup"; fi
  done

  log "Restore record: $backup_id"
  if [ "$restore_yes" != 1 ]; then
    [ -t 0 ] || die "Confirmation required; rerun with --yes."
    printf 'Continue? [y/N] '
    read -r reply
    case "$reply" in y|Y|yes|YES) ;; *) log "Restore cancelled."; return ;; esac
  fi

  for row in "${rows[@]}"; do
    IFS=$'\t' read -r state package target source backup <<< "$row"
    case "$state" in
      absent) restore_remove_links "$target" "$source" ;;
      moved)
        staging="$target.bbldr-restore-$$"
        [[ ! -e "$staging" && ! -L "$staging" ]] || die "Restore staging path already exists: $staging"
        mkdir -p "$(dirname "$staging")"
        cp -a "$backup" "$staging"
        restore_remove_links "$target" "$source"
        if ! mv "$staging" "$target"; then
          log "Restore copy remains at $staging" >&2
          return 1
        fi
        ;;
      managed) log "Kept previously managed target: $target" ;;
    esac
  done
  printf 'restored\n' > "$run_dir/restore-status"
  log "Restore complete."
}

find_original_record() {
  local wanted="$1" directory record
  while IFS= read -r directory; do
    [ -f "$directory/manifest.tsv" ] || continue
    [ "$(cat "$directory/status" 2>/dev/null || true)" = complete ] || continue
    if awk -F '\t' -v package="$wanted" 'NR > 1 && $2 == package && ($1 == "absent" || $1 == "moved") { found=1 } END { exit !found }' "$directory/manifest.tsv"; then
      record="${directory##*/}"
      printf '%s\n' "$record"
      return 0
    fi
  done < <(find "$backup_root" -mindepth 1 -maxdepth 1 -type d -print 2>/dev/null | sort)
  return 1
}

command_uninstall() {
  local uninstall_yes=0 package record target source
  local -a packages=()
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --yes|-y) uninstall_yes=1; shift ;;
      --help|-h)
        cat <<'EOF'
Usage: bbldr dotfiles uninstall [--yes] [PACKAGE...]

Remove managed configuration links and restore pre-install files. Applications,
the Git repository, bbldr, and backup records are retained.
EOF
        return
        ;;
      --*) die "Unknown uninstall option: $1" ;;
      *) packages+=("$1"); shift ;;
    esac
  done
  validate_registry
  if [ "${#packages[@]}" -eq 0 ]; then
    while IFS= read -r package; do packages+=("$package"); done < <(all_packages)
  fi
  validate_packages "${packages[@]}"
  printf 'Packages to uninstall:'; printf ' %s' "${packages[@]}"; printf '\n'
  if [ "$uninstall_yes" != 1 ]; then confirm "Restore their pre-install configuration?" || { log "Uninstall cancelled."; return; }; fi
  for package in "${packages[@]}"; do
    if record="$(find_original_record "$package")"; then
      command_restore --backup "$record" --yes "$package"
      while IFS=$'\t' read -r target source; do remove_source_links "$target" "$source"; done < <(items_for_package "$package")
    else
      log "No original installation record found for $package; leaving it unchanged."
    fi
  done
  log "Applications, repository, bbldr, and backups were retained."
}

command_backups() {
  local directory id status packages marker
  if [ "${1:-}" = --help ] || [ "${1:-}" = -h ]; then printf 'Usage: bbldr dotfiles backups\n'; return; fi
  [ "$#" -eq 0 ] || die "Unknown backups option: $1"
  [ -d "$backup_root" ] || { log "No backups found in $backup_root"; return; }
  printf '%-22s %-13s %-8s %s\n' ID STATUS LATEST PACKAGES
  for directory in "$backup_root"/*; do
    [ -d "$directory" ] || continue
    id="${directory##*/}"
    status="$(cat "$directory/status" 2>/dev/null || printf unknown)"
    packages="$(awk -F '\t' 'NR > 1 && !seen[$2]++ { printf "%s%s", separator, $2; separator="," }' "$directory/manifest.tsv" 2>/dev/null || true)"
    marker=""
    [ -f "$backup_root/latest" ] && [ "$(cat "$backup_root/latest")" = "$id" ] && marker=yes
    printf '%-22s %-13s %-8s %s\n' "$id" "$status" "$marker" "$packages"
  done
}

command_status() {
  local package target source
  if [ "${1:-}" = --help ] || [ "${1:-}" = -h ]; then printf 'Usage: bbldr dotfiles status\n'; return; fi
  [ "$#" -eq 0 ] || die "Unknown status option: $1"
  validate_registry
  printf 'Repository: %s\n' "$repo_root"
  git -C "$repo_root" status --short --branch
  printf '\nManaged paths:\n'
  while IFS= read -r package; do
    while IFS=$'\t' read -r target source; do printf '  %-8s %-16s %s\n' "$package" "$(target_state "$target" "$source")" "$target"; done < <(targets_for_package "$package")
  done < <(all_packages)
  if [ -f "$backup_root/latest" ]; then printf '\nLatest backup: %s\n' "$(cat "$backup_root/latest")"; fi
}

command_doctor() {
  local failures=0 command_name package target source path sensitive_file check_all=0 state
  local -a packages=() required_commands=(git curl)
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --all) check_all=1; shift ;;
      --help|-h)
        cat <<'EOF'
Usage: bbldr dotfiles doctor [--all] [PACKAGE...]

Diagnose installed packages by default, selected packages when supplied, or
every registered package with --all.
EOF
        return
        ;;
      --*) die "Unknown doctor option: $1" ;;
      *) packages+=("$1"); shift ;;
    esac
  done
  validate_registry
  if [ "$check_all" = 1 ] && [ "${#packages[@]}" -gt 0 ]; then die "--all cannot be combined with package names"; fi
  if [ "$check_all" = 1 ]; then
    packages=()
    while IFS= read -r package; do packages+=("$package"); done < <(all_packages)
  elif [ "${#packages[@]}" -eq 0 ]; then
    while IFS= read -r package; do packages+=("$package"); done < <(installed_packages)
  fi
  [ "${#packages[@]}" -eq 0 ] || validate_packages "${packages[@]}"
  [ "${#packages[@]}" -eq 0 ] || required_commands+=(stow)
  for package in "${packages[@]}"; do
    case "$package" in
      nvim) required_commands+=(nvim rg) ;;
      wezterm) required_commands+=(wezterm) ;;
      tmux) required_commands+=(tmux tmux-dev tmux-agent tmux-status) ;;
      zsh) required_commands+=(zsh) ;;
    esac
  done
  log "Repository: $repo_root"
  printf 'Packages:'; if [ "${#packages[@]}" -eq 0 ]; then printf ' none'; else printf ' %s' "${packages[@]}"; fi; printf '\n'
  printf '\nRequired commands:\n'
  while IFS= read -r command_name; do
    if command -v "$command_name" >/dev/null 2>&1; then log "  ok: $command_name ($(command -v "$command_name"))"; else log "  missing: $command_name"; failures=$((failures + 1)); fi
  done < <(printf '%s\n' "${required_commands[@]}" | awk '!seen[$0]++')
  path="$HOME/.local/bin/bbldr"
  if [ -x "$path" ] && bbldr_is_managed; then log "  ok: bbldr"; else log "  missing or unrelated: $path"; failures=$((failures + 1)); fi
  printf '\nConfiguration targets:\n'
  for package in "${packages[@]}"; do
    while IFS=$'\t' read -r target source; do
      state="$(target_state "$target" "$source")"
      log "  $package: $state - $target"
      [ "$state" = managed ] || failures=$((failures + 1))
    done < <(targets_for_package "$package")
  done
  printf '\nGit status:\n'
  git -C "$repo_root" status --short --branch
  printf '\nSensitive tracked filenames:\n'
  sensitive_file="$(mktemp)"
  if git -C "$repo_root" ls-files | grep -En '(credential|credentials|secret|token|password|passwd|access_token|refresh_token|api[_-]?key|client_secret|\.pem$|\.key$|\.p12$|\.pfx$)' > "$sensitive_file"; then
    cat "$sensitive_file"
    failures=$((failures + 1))
  else
    log "  none detected"
  fi
  rm -f "$sensitive_file"
  [ "$failures" -eq 0 ] || die "$failures doctor check(s) failed."
  log "Doctor checks passed."
}

command_update() {
  local package target source link snapshot
  local -a packages=()
  if [ "${1:-}" = --help ] || [ "${1:-}" = -h ]; then printf 'Usage: bbldr dotfiles update\n'; return; fi
  [ "$#" -eq 0 ] || die "Unknown update option: $1"
  [ -d "$repo_root/.git" ] || die "Not a Git repository: $repo_root"
  [ -z "$(git -C "$repo_root" status --porcelain)" ] || die "Update refused because the repository has local changes."
  while IFS= read -r package; do packages+=("$package"); done < <(installed_packages)
  snapshot="$(mktemp)"
  for package in "${packages[@]}"; do
    while IFS=$'\t' read -r target source; do
      [ -L "$target" ] || continue
      printf '%s\t%s\t%s\n' "$target" "$source" "$(readlink "$target")" >> "$snapshot"
    done < <(items_for_package "$package")
  done
  if ! git -C "$repo_root" pull --ff-only; then rm -f "$snapshot"; return 1; fi
  while IFS=$'\t' read -r target source link; do
    if [ ! -e "$source" ] && [ -L "$target" ] && [ "$(readlink "$target")" = "$link" ]; then rm "$target"; fi
  done < "$snapshot"
  rm -f "$snapshot"
  install_cli_commands
  if [ "${#packages[@]}" -gt 0 ]; then command_install --config-only --yes "${packages[@]}"; fi
  command_doctor "${packages[@]}"
}

command_packages() {
  local package default dependency docs _title _description state
  if [ "${1:-}" = --help ] || [ "${1:-}" = -h ]; then printf 'Usage: bbldr dotfiles packages\n'; return; fi
  [ "$#" -eq 0 ] || die "Unknown packages option: $1"
  validate_registry
  printf '%-10s %-9s %-16s %-16s %s\n' PACKAGE DEFAULT DEPENDENCIES STATE DOCS
  while IFS=$'\t' read -r package default dependency docs _title _description; do
    [ "$package" = package ] && continue
    if package_is_installed "$package"; then state=installed; else state=not-installed; fi
    printf '%-10s %-9s %-16s %-16s %s\n' "$package" "$default" "$dependency" "$state" "$docs"
  done < "$packages_file"
}

validate_registry() {
  local _package _target source canonical_repo canonical_source
  awk -F '\t' '
    NR == 1 { if ($0 != "package\tdefault\tdependency\tdocs\ttitle\tdescription") exit 1; next }
    NF != 6 || $1 !~ /^[a-z0-9][a-z0-9-]*$/ || $2 !~ /^[01]$/ || $3 == "" || $4 !~ /^\// || $5 == "" || $6 == "" || seen[$1]++ { exit 1 }
    {
      count=split($3, dependencies, ",")
      for (i=1; i<=count; i++) {
        if (dependencies[i] !~ /^(cli|wezterm|shell|manual)$/ || dependency_seen[$1 SUBSEP dependencies[i]]++) exit 1
      }
    }
  ' "$packages_file" || die "Invalid package registry: $packages_file"
  awk -F '\t' '
    NR == FNR { if (FNR > 1) packages[$1]=1; next }
    FNR == 1 { if ($0 != "package\ttarget\tsource") exit 1; next }
    NF != 3 || !packages[$1] || $2 == "" || $3 == "" || $2 ~ /^\// || $3 ~ /^\// || $2 ~ /(^|\/)\.\.(\/|$)/ || $3 ~ /(^|\/)\.\.(\/|$)/ || seen[$1 FS $2]++ || source_seen[$3]++ { exit 1 }
  ' "$packages_file" "$targets_file" || die "Invalid target registry: $targets_file"
  canonical_repo="$(canonical_future_path "$repo_root")"
  while IFS=$'\t' read -r _package _target source; do
    [ "$_package" = package ] && continue
    [ -e "$repo_root/$source" ] || [ -L "$repo_root/$source" ] || die "Registry source does not exist: $source"
    canonical_source="$(canonical_future_path "$repo_root/$source")"
    case "$canonical_source/" in "$canonical_repo/"*) ;; *) die "Registry source resolves outside the repository: $source" ;; esac
  done < "$targets_file"
}

command_scaffold() {
  local kind="${1:-}" name="${2:-}" target source docs_path
  if [ "$kind" = --help ] || [ "$kind" = -h ]; then printf 'Usage: bbldr dotfiles scaffold app NAME\n'; return; fi
  [ "$#" -eq 2 ] || die "Usage: bbldr dotfiles scaffold app NAME"
  validate_registry
  [[ "$kind" = app && -n "$name" ]] || die "Usage: bbldr dotfiles scaffold app NAME"
  [[ "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]] || die "App names must use lowercase letters, digits, and hyphens."
  package_exists "$name" && die "Package already exists: $name"
  target=".config/$name"
  source="$name/.config/$name"
  docs_path="$repo_root/docs/apps/$name.md"
  [ ! -e "$repo_root/$name" ] || die "Package directory already exists: $repo_root/$name"
  [ ! -e "$docs_path" ] || die "Documentation already exists: $docs_path"
  mkdir -p "$repo_root/$source"
  printf '%s\t0\tmanual\t/apps/%s\t%s\tDescribe what this application adds to the workspace.\n' "$name" "$name" "$name" >> "$packages_file"
  printf '%s\t%s\t%s\n' "$name" "$target" "$source" >> "$targets_file"
  printf '# %s\n\nExplain what the application is and why it belongs in this workspace.\n\n## Official Resources\n\nAdd links to the official website, documentation, and source repository.\n\n## What This Project Configures\n\nDocument every tracked behavior, command, shortcut, path, and dependency.\n\n## Verify And Troubleshoot\n\nAdd commands that verify the effective configuration and explain safe recovery.\n' "$name" > "$docs_path"
  log "Created package scaffold: $name"
  log "Add real configuration files under $source before installing it."
}

command_purge() {
  local purge_yes=0 package
  while [ "$#" -gt 0 ]; do
    case "$1" in
      --yes|-y) purge_yes=1; shift ;;
      --help|-h)
        cat <<'EOF'
Usage: bbldr dotfiles purge [--yes]

Restore all registered configuration, remove managed bbldr commands, and delete
the repository. Backups and system applications are retained.
EOF
        return
        ;;
      --*) die "Unknown purge option: $1" ;;
      *) die "Unexpected purge argument: $1" ;;
    esac
  done
  [ -z "$(git -C "$repo_root" status --porcelain)" ] || die "Purge refused because the repository has local changes."
  if [ "$purge_yes" != 1 ]; then confirm "Restore configurations and remove the dotfiles repository?" || { log "Purge cancelled."; return; }; fi
  command_uninstall --yes
  while IFS= read -r package; do package_is_installed "$package" && die "Purge stopped because $package is still linked."; done < <(all_packages)
  module_command_is_safe && rm -f "$HOME/.local/bin/bbldr-dotfiles"
  bbldr_is_managed && rm -f "$HOME/.local/bin/bbldr"
  cd "$HOME"
  [[ "$repo_root" != / && "$repo_root" != "$HOME" ]] || die "Unsafe repository path: $repo_root"
  rm -rf -- "${repo_root:?}"
  log "Removed $repo_root. Applications and backups were retained."
}

command_check() {
  local -a scripts=(bin/bbldr bin/bbldr-dotfiles install.sh tmux/.local/bin/tmux-dev tmux/.local/bin/tmux-agent tmux/.local/bin/tmux-status tests/install-restore.sh tests/cli.sh)
  if [ "${1:-}" = --help ] || [ "${1:-}" = -h ]; then printf 'Usage: bbldr dotfiles check\n'; return; fi
  [ "$#" -eq 0 ] || die "Unknown check option: $1"
  cd "$repo_root"
  validate_registry
  log "Checking shell syntax"
  bash -n "${scripts[@]}"
  zsh -n zsh/.zshrc
  if command -v shellcheck >/dev/null 2>&1; then log "Running ShellCheck"; shellcheck "${scripts[@]}"; else log "ShellCheck not installed; skipping static shell analysis"; fi
  log "Testing CLI, install, restore, and uninstall"
  tests/cli.sh
  tests/install-restore.sh
  log "Checking documentation links and assets"
  npm run docs:lint
  node tests/docs-links.mjs
  if command -v wezterm >/dev/null 2>&1; then log "Validating WezTerm configuration"; wezterm --config-file wezterm/.config/wezterm/wezterm.lua show-keys >/dev/null; fi
  if command -v nvim >/dev/null 2>&1; then log "Validating Neovim configuration"; NVIM_LOG_FILE="${TMPDIR:-/tmp}/bbldr-nvim-$$.log" nvim --headless -i NONE -u nvim/.config/nvim/init.lua +qa; fi
  if command -v tmux >/dev/null 2>&1 && [ "${BBLDR_SKIP_TMUX_RUNTIME:-0}" != 1 ]; then
    local tmux_socket="${TMPDIR:-/tmp}/bbldr-dotfiles-check-$$.sock"
    log "Validating tmux configuration"
    tmux -S "$tmux_socket" -f tmux/.tmux.conf new-session -d -s bbldr-dotfiles-check
    if ! tmux -S "$tmux_socket" list-keys -T root M-1 | grep -q 'select-pane -t 1'; then tmux -S "$tmux_socket" kill-server; die "tmux M-1 binding is missing"; fi
    tmux -S "$tmux_socket" kill-server
  fi
  if [ "${BBLDR_SKIP_DOCS:-0}" != 1 ]; then log "Building documentation"; npm run docs:build; fi
  git diff --check
  log "All checks passed."
}

command_version() {
  if [ "${1:-}" = --help ] || [ "${1:-}" = -h ]; then printf 'Usage: bbldr dotfiles version\n'; return; fi
  [ "$#" -eq 0 ] || die "Unknown version option: $1"
  printf 'bbldr dotfiles %s\n' "$version"
}

command_help() {
  if [ "${1:-}" = --help ] || [ "${1:-}" = -h ]; then usage; return; fi
  [ "$#" -eq 0 ] || die "Unknown help option: $1"
  usage
}

command_name="${1:-help}"
[ "$#" -eq 0 ] || shift
case "$command_name" in
  install) command_install "$@" ;;
  update) command_update "$@" ;;
  status) command_status "$@" ;;
  doctor) command_doctor "$@" ;;
  packages) command_packages "$@" ;;
  backups) command_backups "$@" ;;
  restore) command_restore "$@" ;;
  uninstall) command_uninstall "$@" ;;
  purge) command_purge "$@" ;;
  scaffold) command_scaffold "$@" ;;
  check) command_check "$@" ;;
  version|-v|--version) command_version "$@" ;;
  help|-h|--help) command_help "$@" ;;
  *) echo "Unknown dotfiles command: $command_name" >&2; usage >&2; exit 2 ;;
esac
