#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

if ! command -v stow >/dev/null 2>&1; then
  echo "stow is not installed. Install it first, then rerun this command."
  exit 1
fi

packages=("$@")
if [ "${#packages[@]}" -eq 0 ]; then
  packages=(nvim wezterm tmux)
fi

stow --target="$HOME" "${packages[@]}"
