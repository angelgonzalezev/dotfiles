#!/usr/bin/env bash
set -euo pipefail

repo_url="${DOTFILES_REPO_URL:-https://github.com/angelgonzalezev/dotfiles.git}"
repo_dir="${DOTFILES_DIR:-$HOME/.config/dotfiles}"
backup_root="${DOTFILES_BACKUP_DIR:-$HOME/.config/dotfiles-backups}"
assume_yes="${DOTFILES_ASSUME_YES:-0}"
packages=("$@")
install_cli_tools=0
install_wezterm=0
install_oh_my_zsh=0
install_zsh_autosuggestions=0
install_nerd_font=0
install_configs=1
run_id=""
run_dir=""
manifest=""
changed_targets=0

if [ "${#packages[@]}" -eq 0 ]; then
  packages=(nvim wezterm tmux zsh)
fi

log() { printf '%s\n' "$*"; }

confirm() {
  local reply
  if [ "$assume_yes" = "1" ]; then return 0; fi
  if [ ! -t 0 ]; then return 1; fi
  printf '%s [y/N] ' "$1"
  read -r reply
  case "$reply" in y|Y|yes|YES) return 0 ;; *) return 1 ;; esac
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    log "missing required command: $1"
    exit 1
  fi
}

platform() {
  case "$(uname -s)" in
    Darwin) printf 'macos\n' ;;
    Linux)
      if command -v apt-get >/dev/null 2>&1; then printf 'debian\n'; else printf 'linux\n'; fi
      ;;
    *) printf 'unsupported\n' ;;
  esac
}

activate_homebrew() {
  local candidate
  if command -v brew >/dev/null 2>&1; then return; fi
  for candidate in /opt/homebrew/bin/brew /usr/local/bin/brew; do
    if [ -x "$candidate" ]; then
      eval "$("$candidate" shellenv)"
      return
    fi
  done
}

install_homebrew() {
  activate_homebrew
  if command -v brew >/dev/null 2>&1; then return; fi
  if [ "$(platform)" != "macos" ]; then
    log "Homebrew automatic installation is only used on macOS."
    exit 1
  fi
  if ! confirm "Homebrew is missing. Install Homebrew?"; then
    log "Homebrew is required to install macOS dependencies automatically."
    exit 1
  fi
  log "installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  activate_homebrew
  require_command brew
}

brew_install_formula() {
  if brew list --formula "$1" >/dev/null 2>&1; then log "already installed: $1"; else brew install "$1"; fi
}

brew_install_cask() {
  if brew list --cask "$1" >/dev/null 2>&1; then log "already installed: $1"; else brew install --cask "$1"; fi
}

apt_install() {
  local missing=() item
  for item in "$@"; do
    if ! dpkg -s "$item" >/dev/null 2>&1; then missing+=("$item"); fi
  done
  if [ "${#missing[@]}" -gt 0 ]; then
    log "installing apt packages: ${missing[*]}"
    sudo apt-get update
    sudo apt-get install -y "${missing[@]}"
  fi
}

version_at_least() {
  [ "$(printf '%s\n%s\n' "$2" "$1" | sort -V | head -n 1)" = "$2" ]
}

check_neovim_version() {
  local version
  if ! command -v nvim >/dev/null 2>&1; then return 1; fi
  version="$(nvim --version | head -n 1 | sed -E 's/.*v([0-9]+\.[0-9]+\.[0-9]+).*/\1/')"
  version_at_least "$version" "0.10.0"
}

install_current_neovim_linux() {
  local arch asset tmp_dir install_dir command_path
  case "$(uname -m)" in x86_64) arch=x86_64 ;; aarch64|arm64) arch=arm64 ;; *) log "unsupported Neovim architecture: $(uname -m)"; exit 1 ;; esac
  asset="nvim-linux-${arch}.tar.gz"
  tmp_dir="$(mktemp -d)"
  install_dir="$HOME/.local/opt/dotfiles-nvim"
  command_path="$HOME/.local/bin/nvim"
  if [ -e "$command_path" ] && [ ! -L "$command_path" ]; then
    log "refusing to overwrite existing command: $command_path"
    exit 1
  fi
  if [ -L "$command_path" ] && [[ "$(readlink "$command_path")" != "$install_dir"/* ]]; then
    log "refusing to replace unrelated symlink: $command_path"
    exit 1
  fi
  log "installing current Neovim release in $install_dir"
  curl -fsSL "https://github.com/neovim/neovim/releases/latest/download/$asset" -o "$tmp_dir/nvim.tar.gz"
  tar -xzf "$tmp_dir/nvim.tar.gz" -C "$tmp_dir"
  mkdir -p "$HOME/.local/opt" "$HOME/.local/bin"
  if [ -d "$install_dir" ]; then mv "$install_dir" "$install_dir.previous-$(date +%Y%m%d-%H%M%S)"; fi
  mv "$tmp_dir/nvim-linux-${arch}" "$install_dir"
  ln -sfn "$install_dir/bin/nvim" "$command_path"
  rm -rf "$tmp_dir"
  export PATH="$HOME/.local/bin:$PATH"
}

install_cli_dependencies() {
  case "$(platform)" in
    macos)
      install_homebrew
      brew_install_formula stow
      brew_install_formula neovim
      brew_install_formula tmux
      brew_install_formula ripgrep
      ;;
    debian)
      apt_install stow tmux ripgrep zsh ca-certificates
      if ! check_neovim_version; then install_current_neovim_linux; fi
      ;;
    *) log "automatic dependency installation supports macOS and Ubuntu/Debian only"; exit 1 ;;
  esac
}

install_wezterm_dependency() {
  case "$(platform)" in
    macos) install_homebrew; brew_install_cask wezterm ;;
    debian)
      if command -v wezterm >/dev/null 2>&1; then log "already installed: wezterm"; return; fi
      apt_install ca-certificates curl gnupg
      curl -fsSL https://apt.fury.io/wez/gpg.key | sudo gpg --yes --dearmor -o /usr/share/keyrings/wezterm-fury.gpg
      printf '%s\n' 'deb [signed-by=/usr/share/keyrings/wezterm-fury.gpg] https://apt.fury.io/wez/ * *' | sudo tee /etc/apt/sources.list.d/wezterm.list >/dev/null
      sudo chmod 644 /usr/share/keyrings/wezterm-fury.gpg
      sudo apt-get update
      sudo apt-get install -y wezterm
      ;;
    *) log "install WezTerm manually on this Linux distribution" ;;
  esac
}

install_nerd_font_dependency() {
  local font_dir tmp_dir
  case "$(platform)" in
    macos) install_homebrew; brew_install_cask font-jetbrains-mono-nerd-font ;;
    debian)
      apt_install curl xz-utils fontconfig
      font_dir="$HOME/.local/share/fonts/JetBrainsMonoNerdFont"
      if find "$font_dir" -type f -name '*.ttf' -print -quit 2>/dev/null | grep -q .; then
        log "already installed: JetBrainsMono Nerd Font"
        return
      fi
      tmp_dir="$(mktemp -d)"
      curl -fsSL https://github.com/ryanoasis/nerd-fonts/releases/latest/download/JetBrainsMono.tar.xz -o "$tmp_dir/font.tar.xz"
      mkdir -p "$font_dir"
      tar -xJf "$tmp_dir/font.tar.xz" -C "$font_dir"
      rm -rf "$tmp_dir"
      if command -v fc-cache >/dev/null 2>&1; then fc-cache -f "$font_dir"; fi
      ;;
    *) log "install JetBrainsMono Nerd Font manually on this platform" ;;
  esac
}

install_oh_my_zsh_dependency() {
  if [ -d "$HOME/.oh-my-zsh" ]; then log "already installed: Oh My Zsh"; return; fi
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
}

install_zsh_autosuggestions_dependency() {
  local plugin_dir="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/zsh-autosuggestions"
  if [ -d "$plugin_dir" ]; then log "already installed: zsh-autosuggestions"; return; fi
  if [ ! -d "$HOME/.oh-my-zsh" ]; then log "Oh My Zsh is required before zsh-autosuggestions"; return; fi
  git clone https://github.com/zsh-users/zsh-autosuggestions "$plugin_dir"
}

configure_interactive_install() {
  if [ "$assume_yes" = "1" ]; then
    install_cli_tools=1; install_wezterm=1; install_oh_my_zsh=1
    install_zsh_autosuggestions=1; install_nerd_font=1; return
  fi
  if [ ! -t 0 ]; then return; fi
  log "dotfiles bootstrap ($(platform))"
  confirm "Install CLI tools (stow, Neovim, tmux, ripgrep and Zsh)?" && install_cli_tools=1
  confirm "Install WezTerm?" && install_wezterm=1
  confirm "Install JetBrainsMono Nerd Font?" && install_nerd_font=1
  confirm "Install Oh My Zsh?" && install_oh_my_zsh=1
  confirm "Install zsh-autosuggestions?" && install_zsh_autosuggestions=1
  if ! confirm "Install dotfiles packages (${packages[*]})?"; then install_configs=0; fi
}

install_selected_dependencies() {
  if [ "$install_cli_tools" = "1" ]; then install_cli_dependencies; fi
  if [ "$install_wezterm" = "1" ]; then install_wezterm_dependency; fi
  if [ "$install_nerd_font" = "1" ]; then install_nerd_font_dependency; fi
  if [ "$install_oh_my_zsh" = "1" ]; then install_oh_my_zsh_dependency; fi
  if [ "$install_zsh_autosuggestions" = "1" ]; then install_zsh_autosuggestions_dependency; fi
}

install_stow() {
  if command -v stow >/dev/null 2>&1; then return; fi
  case "$(platform)" in
    macos) install_homebrew; brew_install_formula stow ;;
    debian) apt_install stow ;;
    *) log "stow is missing; install it manually and rerun"; exit 1 ;;
  esac
}

clone_or_update_repo() {
  if [ -d "$repo_dir/.git" ]; then
    log "updating dotfiles repo: $repo_dir"
    git -C "$repo_dir" pull --ff-only
  elif [ -e "$repo_dir" ]; then
    log "target exists but is not a git repository: $repo_dir"; exit 1
  else
    mkdir -p "$(dirname "$repo_dir")"
    git clone "$repo_url" "$repo_dir"
  fi
}

validate_packages() {
  local package
  for package in "${packages[@]}"; do
    case "$package" in nvim|wezterm|tmux|zsh) ;; *) log "unknown package: $package"; exit 1 ;; esac
  done
}

targets_for_package() {
  case "$1" in
    nvim) printf '%s\t%s\n' "$HOME/.config/nvim" "$repo_dir/nvim/.config/nvim" ;;
    wezterm) printf '%s\t%s\n' "$HOME/.config/wezterm" "$repo_dir/wezterm/.config/wezterm" ;;
    tmux)
      printf '%s\t%s\n' "$HOME/.tmux.conf" "$repo_dir/tmux/.tmux.conf"
      printf '%s\t%s\n' "$HOME/.local/bin/tmux-dev" "$repo_dir/tmux/.local/bin/tmux-dev"
      printf '%s\t%s\n' "$HOME/.local/bin/tmux-agent" "$repo_dir/tmux/.local/bin/tmux-agent"
      printf '%s\t%s\n' "$HOME/.local/bin/tmux-status" "$repo_dir/tmux/.local/bin/tmux-status"
      ;;
    zsh) printf '%s\t%s\n' "$HOME/.zshrc" "$repo_dir/zsh/.zshrc" ;;
  esac
}

resolve_link() {
  local path="$1" link
  link="$(readlink "$path")"
  case "$link" in /*) realpath "$link" ;; *) realpath "$(dirname "$path")/$link" ;; esac
}

target_is_managed() {
  local target="$1" source="$2" source_file relative live
  if [ -f "$source" ] || [ -L "$source" ]; then
    [ -L "$target" ] && [ "$(resolve_link "$target")" = "$(realpath "$source")" ]
    return
  fi
  [ -d "$target" ] || return 1
  while IFS= read -r source_file; do
    relative="${source_file#"$source"/}"
    live="$target/$relative"
    if [ ! -L "$live" ] || [ "$(resolve_link "$live")" != "$(realpath "$source_file")" ]; then return 1; fi
  done < <(find "$source" \( -type f -o -type l \) -print)
}

backup_path() { printf '%s%s\n' "$run_dir" "$1"; }

create_manifest() {
  local suffix=0
  run_id="$(date +%Y%m%d-%H%M%S)"
  while [ -e "$backup_root/$run_id" ]; do suffix=$((suffix + 1)); run_id="$(date +%Y%m%d-%H%M%S)-$suffix"; done
  run_dir="$backup_root/$run_id"
  manifest="$run_dir/manifest.tsv"
  mkdir -p "$run_dir"
  printf 'state\tpackage\ttarget\tsource\tbackup\n' > "$manifest"
  printf 'running\n' > "$run_dir/status"
}

backup_existing_targets() {
  local package target source backup state
  for package in "${packages[@]}"; do
    while IFS=$'\t' read -r target source; do
      backup="$(backup_path "$target")"
      if [ ! -e "$target" ] && [ ! -L "$target" ]; then
        state=absent
        changed_targets=1
      elif target_is_managed "$target" "$source"; then
        state=managed
      else
        state=moved
        changed_targets=1
        mkdir -p "$(dirname "$backup")"
        log "backing up $target to $backup"
        mv "$target" "$backup"
      fi
      printf '%s\t%s\t%s\t%s\t%s\n' "$state" "$package" "$target" "$source" "$backup" >> "$manifest"
    done < <(targets_for_package "$package")
  done
}

remove_source_links() {
  local target="$1" source="$2" source_file relative live
  if [ -f "$source" ] || [ -L "$source" ]; then
    if [ -L "$target" ] && [ "$(resolve_link "$target")" = "$(realpath "$source")" ]; then rm "$target"; fi
    return
  fi
  while IFS= read -r source_file; do
    relative="${source_file#"$source"/}"
    live="$target/$relative"
    if [ -L "$live" ] && [ "$(resolve_link "$live")" = "$(realpath "$source_file")" ]; then rm "$live"; fi
  done < <(find "$source" \( -type f -o -type l \) -print)
  find "$target" -depth -type d -empty -delete 2>/dev/null || true
}

rollback_install() {
  local state package target source backup
  log "installation failed; restoring files from $run_id"
  tail -n +2 "$manifest" | while IFS=$'\t' read -r state package target source backup; do
    case "$state" in
      absent) remove_source_links "$target" "$source" ;;
      moved)
        remove_source_links "$target" "$source"
        if [ ! -e "$target" ] && [ ! -L "$target" ] && [ -e "$backup" ]; then mkdir -p "$(dirname "$target")"; mv "$backup" "$target"; fi
        ;;
    esac
  done
  printf 'rolled-back\n' > "$run_dir/status"
}

link_packages() {
  if ! stow --simulate --no-folding --target="$HOME" --dir="$repo_dir" "${packages[@]}"; then rollback_install; return 1; fi
  if ! "$repo_dir/bin/dotfiles-install" "${packages[@]}"; then rollback_install; return 1; fi
}

main() {
  local restore_id
  require_command git
  require_command curl
  validate_packages
  configure_interactive_install
  install_selected_dependencies
  if [ "$install_configs" != "1" ]; then log "skipping dotfiles package installation"; return; fi
  install_stow
  clone_or_update_repo
  create_manifest
  backup_existing_targets
  log "installing packages: ${packages[*]}"
  link_packages
  printf 'complete\n' > "$run_dir/status"
  if [ "$changed_targets" = 1 ] || [ ! -f "$backup_root/latest" ]; then
    printf '%s\n' "$run_id" > "$backup_root/latest"
  else
    log "no target changes; keeping the previous restore point"
  fi
  restore_id="$(cat "$backup_root/latest")"
  log "installation record: $run_dir"
  log "restore command: $repo_dir/bin/dotfiles-restore --backup $restore_id"
  log "done"
}

main
