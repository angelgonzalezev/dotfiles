#!/usr/bin/env bash
set -euo pipefail

repo_url="${DOTFILES_REPO_URL:-https://github.com/angelgonzalezev/dotfiles.git}"
repo_dir="${DOTFILES_DIR:-$HOME/.config/dotfiles}"
backup_root="${DOTFILES_BACKUP_DIR:-$HOME/.config/dotfiles-backups}"
packages=("$@")
assume_yes="${DOTFILES_ASSUME_YES:-0}"
install_cli_tools=0
install_wezterm=0
install_oh_my_zsh=0
install_zsh_autosuggestions=0
install_configs=1

if [ "${#packages[@]}" -eq 0 ]; then
  packages=(nvim wezterm tmux zsh)
fi

log() {
  printf '%s\n' "$*"
}

confirm() {
  local prompt reply
  prompt="$1"

  if [ "$assume_yes" = "1" ]; then
    return 0
  fi

  if [ ! -t 0 ]; then
    return 1
  fi

  printf '%s [y/N] ' "$prompt"
  read -r reply

  case "$reply" in
    y|Y|yes|YES) return 0 ;;
    *) return 1 ;;
  esac
}

require_command() {
  if ! command -v "$1" >/dev/null 2>&1; then
    log "missing required command: $1"
    exit 1
  fi
}

install_stow() {
  if command -v stow >/dev/null 2>&1; then
    return
  fi

  if ! command -v brew >/dev/null 2>&1; then
    log "stow is not installed and Homebrew was not found."
    log "Install Homebrew or install stow manually, then rerun this script."
    exit 1
  fi

  log "installing stow with Homebrew"
  brew install stow
}

install_homebrew() {
  if command -v brew >/dev/null 2>&1; then
    return
  fi

  if ! confirm "Homebrew is missing. Install Homebrew?"; then
    log "Homebrew is required to install dependencies automatically."
    log "Install Homebrew manually or rerun with DOTFILES_ASSUME_YES=1."
    exit 1
  fi

  log "installing Homebrew"
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
}

brew_install_formula() {
  local formula
  formula="$1"

  if brew list --formula "$formula" >/dev/null 2>&1; then
    log "already installed: $formula"
    return
  fi

  log "installing formula: $formula"
  brew install "$formula"
}

brew_install_cask() {
  local cask
  cask="$1"

  if brew list --cask "$cask" >/dev/null 2>&1; then
    log "already installed: $cask"
    return
  fi

  log "installing cask: $cask"
  brew install --cask "$cask"
}

install_cli_dependencies() {
  brew_install_formula stow
  brew_install_formula neovim
  brew_install_formula tmux
}

install_oh_my_zsh_dependency() {
  if [ -d "$HOME/.oh-my-zsh" ]; then
    log "already installed: Oh My Zsh"
    return
  fi

  log "installing Oh My Zsh"
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
}

install_zsh_autosuggestions_dependency() {
  local plugin_dir
  plugin_dir="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}/plugins/zsh-autosuggestions"

  if [ -d "$plugin_dir" ]; then
    log "already installed: zsh-autosuggestions"
    return
  fi

  if [ ! -d "$HOME/.oh-my-zsh" ]; then
    log "Oh My Zsh is required before installing zsh-autosuggestions."
    return
  fi

  log "installing zsh-autosuggestions"
  git clone https://github.com/zsh-users/zsh-autosuggestions "$plugin_dir"
}

configure_interactive_install() {
  if [ "$assume_yes" = "1" ]; then
    install_cli_tools=1
    install_wezterm=1
    install_oh_my_zsh=1
    install_zsh_autosuggestions=1
    install_configs=1
    return
  fi

  if [ ! -t 0 ]; then
    install_cli_tools=0
    install_wezterm=0
    install_oh_my_zsh=0
    install_zsh_autosuggestions=0
    install_configs=1
    return
  fi

  log "dotfiles bootstrap"
  log "This installer can install apps and link configuration files."
  log ""

  if confirm "Install CLI tools with Homebrew (stow, neovim, tmux)?"; then
    install_cli_tools=1
  fi

  if confirm "Install WezTerm with Homebrew Cask?"; then
    install_wezterm=1
  fi

  if confirm "Install Oh My Zsh?"; then
    install_oh_my_zsh=1
  fi

  if confirm "Install zsh-autosuggestions?"; then
    install_zsh_autosuggestions=1
  fi

  if confirm "Install dotfiles packages (${packages[*]})?"; then
    install_configs=1
  else
    install_configs=0
  fi
}

install_selected_dependencies() {
  if [ "$install_cli_tools" = "1" ] || [ "$install_wezterm" = "1" ]; then
    install_homebrew
  fi

  if [ "$install_cli_tools" = "1" ]; then
    install_cli_dependencies
  fi

  if [ "$install_wezterm" = "1" ]; then
    brew_install_cask wezterm
  fi

  if [ "$install_oh_my_zsh" = "1" ]; then
    install_oh_my_zsh_dependency
  fi

  if [ "$install_zsh_autosuggestions" = "1" ]; then
    install_zsh_autosuggestions_dependency
  fi
}

clone_or_update_repo() {
  if [ -d "$repo_dir/.git" ]; then
    log "updating dotfiles repo: $repo_dir"
    git -C "$repo_dir" pull --ff-only
    return
  fi

  if [ -e "$repo_dir" ]; then
    log "target exists but is not a git repository: $repo_dir"
    log "Move it away or set DOTFILES_DIR to a different path."
    exit 1
  fi

  log "cloning dotfiles repo: $repo_dir"
  mkdir -p "$(dirname "$repo_dir")"
  git clone "$repo_url" "$repo_dir"
}

targets_for_package() {
  case "$1" in
    nvim)
      printf '%s\n' "$HOME/.config/nvim"
      ;;
    wezterm)
      printf '%s\n' "$HOME/.config/wezterm"
      ;;
    tmux)
      printf '%s\n' "$HOME/.tmux.conf"
      printf '%s\n' "$HOME/.local/bin/tmux-dev"
      printf '%s\n' "$HOME/.local/bin/tmux-agent"
      ;;
    zsh)
      printf '%s\n' "$HOME/.zshrc"
      ;;
    *)
      log "unknown package: $1"
      exit 1
      ;;
  esac
}

source_for_target() {
  case "$1" in
    nvim) printf '%s\n' "$repo_dir/nvim/.config/nvim" ;;
    wezterm) printf '%s\n' "$repo_dir/wezterm/.config/wezterm" ;;
    tmux)
      case "$2" in
        "$HOME/.tmux.conf") printf '%s\n' "$repo_dir/tmux/.tmux.conf" ;;
        "$HOME/.local/bin/tmux-dev") printf '%s\n' "$repo_dir/tmux/.local/bin/tmux-dev" ;;
        "$HOME/.local/bin/tmux-agent") printf '%s\n' "$repo_dir/tmux/.local/bin/tmux-agent" ;;
        *)
          log "unknown tmux target: $2"
          exit 1
          ;;
      esac
      ;;
    zsh) printf '%s\n' "$repo_dir/zsh/.zshrc" ;;
    *)
      log "unknown package: $1"
      exit 1
      ;;
  esac
}

backup_path_for_target() {
  case "$1" in
    nvim) printf '%s\n' "$backup_root/$2/.config/nvim" ;;
    wezterm) printf '%s\n' "$backup_root/$2/.config/wezterm" ;;
    tmux)
      case "$3" in
        "$HOME/.tmux.conf") printf '%s\n' "$backup_root/$2/.tmux.conf" ;;
        "$HOME/.local/bin/tmux-dev") printf '%s\n' "$backup_root/$2/.local/bin/tmux-dev" ;;
        "$HOME/.local/bin/tmux-agent") printf '%s\n' "$backup_root/$2/.local/bin/tmux-agent" ;;
        *)
          log "unknown tmux target: $3"
          exit 1
          ;;
      esac
      ;;
    zsh) printf '%s\n' "$backup_root/$2/.zshrc" ;;
    *)
      log "unknown package: $1"
      exit 1
      ;;
  esac
}

resolve_path() {
  local path link dir base
  path="$1"

  if [ -L "$path" ]; then
    link="$(readlink "$path")"
    if [[ "$link" = /* ]]; then
      path="$link"
    else
      path="$(dirname "$path")/$link"
    fi
  fi

  dir="$(dirname "$path")"
  base="$(basename "$path")"
  printf '%s/%s\n' "$(cd "$dir" && pwd -P)" "$base"
}

backup_existing_targets() {
  local timestamp package target source backup_path
  timestamp="$(date +%Y%m%d-%H%M%S)"

  for package in "${packages[@]}"; do
    while IFS= read -r target; do
      source="$(source_for_target "$package" "$target")"
      backup_path="$(backup_path_for_target "$package" "$timestamp" "$target")"

      if [ ! -e "$target" ] && [ ! -L "$target" ]; then
        continue
      fi

      if [ -L "$target" ] && [ "$(resolve_path "$target")" = "$(resolve_path "$source")" ]; then
        log "already linked: $target"
        continue
      fi

      mkdir -p "$(dirname "$backup_path")"
      log "backing up $target to $backup_path"
      mv "$target" "$backup_path"
    done < <(targets_for_package "$package")
  done
}

validate_packages() {
  local package

  for package in "${packages[@]}"; do
    case "$package" in
      nvim|wezterm|tmux|zsh) ;;
      *)
        log "unknown package: $package"
        exit 1
        ;;
    esac
  done
}

main() {
  require_command git
  validate_packages
  configure_interactive_install
  install_selected_dependencies

  if [ "$install_configs" != "1" ]; then
    log "skipping dotfiles package installation"
    log "done"
    return
  fi

  install_stow
  clone_or_update_repo
  backup_existing_targets

  log "installing packages: ${packages[*]}"
  "$repo_dir/bin/dotfiles-install" "${packages[@]}"

  log "done"
}

main
