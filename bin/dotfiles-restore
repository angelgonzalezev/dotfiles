#!/usr/bin/env bash
set -euo pipefail

backup_root="${DOTFILES_BACKUP_DIR:-$HOME/.config/dotfiles-backups}"
backup_id=latest
assume_yes=0
packages=()

usage() {
  cat <<'EOF'
Usage: dotfiles-restore [--backup latest|TIMESTAMP] [--yes] [PACKAGE...]

Restore configuration files saved by the dotfiles bootstrap. If no package is
provided, every package recorded in the selected installation is restored.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --backup) [ "$#" -ge 2 ] || { echo "--backup requires a value"; exit 2; }; backup_id="$2"; shift 2 ;;
    --yes|-y) assume_yes=1; shift ;;
    --help|-h) usage; exit 0 ;;
    --*) echo "unknown option: $1"; usage; exit 2 ;;
    *) packages+=("$1"); shift ;;
  esac
done

if [ "$backup_id" = latest ]; then
  [ -f "$backup_root/latest" ] || { echo "no completed installation record found in $backup_root"; exit 1; }
  backup_id="$(cat "$backup_root/latest")"
fi

run_dir="$backup_root/$backup_id"
manifest="$run_dir/manifest.tsv"
[ -f "$manifest" ] || { echo "manifest not found: $manifest"; exit 1; }

selected() {
  local wanted
  if [ "${#packages[@]}" -eq 0 ]; then return 0; fi
  for wanted in "${packages[@]}"; do [ "$wanted" = "$1" ] && return 0; done
  return 1
}

resolve_link() {
  local path="$1" link
  link="$(readlink "$path")"
  case "$link" in /*) realpath "$link" ;; *) realpath "$(dirname "$path")/$link" ;; esac
}

link_matches() {
  [ -L "$1" ] && [ "$(resolve_link "$1")" = "$(realpath "$2")" ]
}

directory_is_safe() {
  local target="$1" source="$2" live relative expected
  [ -d "$target" ] || return 0
  while IFS= read -r live; do
    relative="${live#"$target"/}"
    expected="$source/$relative"
    if [ ! -e "$expected" ] && [ ! -L "$expected" ]; then return 1; fi
    link_matches "$live" "$expected" || return 1
  done < <(find "$target" \( -type f -o -type l \) -print)
}

target_is_safe() {
  local target="$1" source="$2"
  if [ ! -e "$target" ] && [ ! -L "$target" ]; then return 0; fi
  if [ -d "$source" ]; then
    [ -d "$target" ] && [ ! -L "$target" ] || return 1
    directory_is_safe "$target" "$source"
  else
    link_matches "$target" "$source"
  fi
}

remove_links() {
  local target="$1" source="$2" source_file relative live
  if [ ! -d "$source" ]; then
    if link_matches "$target" "$source"; then rm "$target"; fi
    return 0
  fi
  while IFS= read -r source_file; do
    relative="${source_file#"$source"/}"
    live="$target/$relative"
    link_matches "$live" "$source_file" && rm "$live"
  done < <(find "$source" \( -type f -o -type l \) -print)
  find "$target" -depth -type d -empty -delete 2>/dev/null || true
}

declare -a rows=()
while IFS=$'\t' read -r state package target source backup; do
  [ "$state" = state ] && continue
  selected "$package" || continue
  rows+=("$state"$'\t'"$package"$'\t'"$target"$'\t'"$source"$'\t'"$backup")
done < "$manifest"

[ "${#rows[@]}" -gt 0 ] || { echo "no matching packages in $manifest"; exit 1; }

for row in "${rows[@]}"; do
  IFS=$'\t' read -r state package target source backup <<< "$row"
  if ! target_is_safe "$target" "$source"; then
    echo "refusing to overwrite a modified path: $target"
    echo "Move it elsewhere, then run the restore command again."
    exit 1
  fi
  if [ "$state" = moved ] && [ ! -e "$backup" ] && [ ! -L "$backup" ]; then
    echo "backup item is missing: $backup"
    exit 1
  fi
done

echo "restore record: $backup_id"
printf 'packages:'
for package in "${packages[@]}"; do printf ' %s' "$package"; done
[ "${#packages[@]}" -eq 0 ] && printf ' all'
printf '\n'

if [ "$assume_yes" != 1 ]; then
  [ -t 0 ] || { echo "confirmation required; rerun with --yes"; exit 1; }
  printf 'Continue? [y/N] '
  read -r reply
  case "$reply" in y|Y|yes|YES) ;; *) echo "restore cancelled"; exit 0 ;; esac
fi

for row in "${rows[@]}"; do
  IFS=$'\t' read -r state package target source backup <<< "$row"
  case "$state" in
    absent) remove_links "$target" "$source" ;;
    moved)
      remove_links "$target" "$source"
      mkdir -p "$(dirname "$target")"
      cp -a "$backup" "$target"
      ;;
    managed) echo "kept previously managed target: $target" ;;
  esac
done

printf 'restored\n' > "$run_dir/restore-status"
echo "restore complete"
